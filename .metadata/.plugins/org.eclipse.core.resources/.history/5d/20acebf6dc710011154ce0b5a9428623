package com.os.service;

import com.os.model.Process;
import com.os.model.ProcessState;
import org.springframework.stereotype.Service;

import java.util.Queue;
import java.util.List;
import java.util.ArrayList;
import java.util.concurrent.ConcurrentLinkedQueue;

@Service
public class AdvancedSchedulerService {

    private final Queue<Process> queue = new ConcurrentLinkedQueue<>();
    private final List<Process> completed = new ArrayList<>();
    private boolean cpuBusy = false;

    // ➕ ADD PROCESS TO QUEUE
    public void addProcess(Process p) {
        p.setState(ProcessState.READY);
        p.setArrivalTime(System.currentTimeMillis());
        p.setRemainingTime(p.getBurstTime());
        queue.add(p);
    }

    // ⚙️ FCFS EXECUTION
    public void executeFCFS() {

        if (cpuBusy) return;

        Process p = queue.poll();
        if (p == null) return;

        cpuBusy = true;

        new Thread(() -> {
            try {
                p.setState(ProcessState.RUNNING);
                p.setStartTime(System.currentTimeMillis());

                Thread.sleep(p.getBurstTime() * 1000L);

                p.setState(ProcessState.TERMINATED);
                p.setEndTime(System.currentTimeMillis());

                completed.add(p);

            } catch (Exception e) {
                e.printStackTrace();
            }

            cpuBusy = false;

        }).start();
    }

    // ✅ BACKWARD COMPATIBILITY (VERY IMPORTANT)
    public void executeNext() {
        executeFCFS();
    }

    public Queue<Process> getQueue() {
        return queue;
    }

    public List<Process> getCompleted() {
        return completed;
    }
}