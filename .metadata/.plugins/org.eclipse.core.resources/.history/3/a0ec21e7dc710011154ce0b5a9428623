package com.os.controller;

import com.os.dto.ProcessRequest;
import com.os.model.Process;
import com.os.service.ProcessService;
import com.os.service.SchedulerService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController
@RequestMapping("/api/process")
@CrossOrigin(origins = "http://localhost:4200")
public class ProcessController {

    @Autowired
    private ProcessService processService;

    @Autowired
    private SchedulerService schedulerService;

    // BASIC CREATE (just stores process)
    @PostMapping("/create")
    public Process createProcess(@RequestBody ProcessRequest request) {
        return processService.createProcess(
                request.getName(),
                request.getBurstTime()
        );
    }

    // ADD TO SCHEDULER QUEUE
    @PostMapping("/schedule")
    public String scheduleProcess(@RequestBody ProcessRequest request) {

        Process p = processService.createProcess(
                request.getName(),
                request.getBurstTime()
        );

        schedulerService.addProcess(p);

        return "Added to queue";
    }

    // EXECUTE NEXT PROCESS (FCFS)
    @PostMapping("/execute")
    public String execute() {
        schedulerService.executeNext();
        return "Executed next process";
    }

    // GET ALL PROCESSES
    @GetMapping("/all")
    public List<Process> getAllProcesses() {
        return processService.getAllProcesses();
    }
}